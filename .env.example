# -------------------------------------------------------
# Application
# -------------------------------------------------------
APP_NAME="Slim Starter"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_SECRET=change-this-to-a-random-32-character-string

# Routing mode: "web" loads views + API routes under /api
#               "api"  loads only API routes (pure JSON API)
APP_MODE=web

# Template engine: "twig" (default) or "php" (legacy plain-PHP views)
APP_TEMPLATE_ENGINE=twig

# -------------------------------------------------------
# Database
# -------------------------------------------------------

# For shared dev-databases network (recommended for local dev)
# DB_HOST=dev_mysql
# For standalone DB container
# DB_HOST=db
DB_HOST=dev_mysql
DB_PORT=3306
DB_DATABASE=slim_starter
DB_USERNAME=root
DB_PASSWORD=devroot
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -------------------------------------------------------
# Mail  (use Mailhog locally — see docker-compose.yml)
# -------------------------------------------------------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="Slim Starter"

# -------------------------------------------------------
# Session
# -------------------------------------------------------
SESSION_LIFETIME=120
SESSION_PATH=../storage/sessions
