{
    "name": "slim-starter/slim-starter",
    "description": "A minimal but modern PHP starter framework built on Slim 4",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/database": "^11.0",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^6.9",
        "respect/validation": "^2.3",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
