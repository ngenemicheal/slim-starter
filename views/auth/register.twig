{% extends 'layout.twig' %}

{% block content %}
<div class="page-narrow">
    <div class="card">

        <div class="card-title">Create account</div>
        <div class="card-subtitle">It only takes a few seconds.</div>

        <form method="POST" action="/register" novalidate>

            <div class="form-group">
                <label class="form-label" for="name">Full name</label>
                <input id="name" name="name" type="text"
                       class="form-input {{ errors.name is defined ? 'error' : '' }}"
                       value="{{ old.name ?? '' }}"
                       autocomplete="name" required>
                {% if errors.name is defined %}
                    <div class="form-error">{{ errors.name }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input id="email" name="email" type="email"
                       class="form-input {{ errors.email is defined ? 'error' : '' }}"
                       value="{{ old.email ?? '' }}"
                       autocomplete="email" required>
                {% if errors.email is defined %}
                    <div class="form-error">{{ errors.email }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input id="password" name="password" type="password"
                       class="form-input {{ errors.password is defined ? 'error' : '' }}"
                       autocomplete="new-password" required minlength="8">
                {% if errors.password is defined %}
                    <div class="form-error">{{ errors.password }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary">Create account</button>

        </form>

        <div class="auth-footer">
            Already have an account? <a href="/login">Sign in</a>
        </div>

    </div>
</div>
{% endblock %}
