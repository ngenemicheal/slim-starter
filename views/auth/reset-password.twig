{% extends 'layout.twig' %}

{% block content %}
<div class="page-narrow">
    <div class="card">

        <div class="card-title">Choose a new password</div>
        <div class="card-subtitle">Enter a new password for your account.</div>

        <form method="POST" action="/reset-password/{{ token }}" novalidate>

            <div class="form-group">
                <label class="form-label" for="password">New password</label>
                <input id="password" name="password" type="password"
                       class="form-input {{ errors.password is defined ? 'error' : '' }}"
                       autocomplete="new-password" required>
                {% if errors.password is defined %}
                    <div class="form-error">{{ errors.password }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label" for="password_confirm">Confirm new password</label>
                <input id="password_confirm" name="password_confirm" type="password"
                       class="form-input {{ errors.password_confirm is defined ? 'error' : '' }}"
                       autocomplete="new-password" required>
                {% if errors.password_confirm is defined %}
                    <div class="form-error">{{ errors.password_confirm }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary">Reset password</button>

        </form>

        <div class="auth-footer">
            <a href="/login">&larr; Back to sign in</a>
        </div>

    </div>
</div>
{% endblock %}
