{% extends 'layout.twig' %}

{% block content %}
<div class="page-narrow">
    <div class="card">

        <div class="card-title">Forgot your password?</div>
        <div class="card-subtitle">Enter your email and we'll send you a reset link.</div>

        {% if flash('success') %}
            <div class="alert alert-success">{{ flash('success') }}</div>
        {% endif %}

        <form method="POST" action="/forgot-password" novalidate>

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input id="email" name="email" type="email"
                       class="form-input {{ errors.email is defined ? 'error' : '' }}"
                       value="{{ old.email ?? '' }}"
                       autocomplete="email" required>
                {% if errors.email is defined %}
                    <div class="form-error">{{ errors.email }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary">Send reset link</button>

        </form>

        <div class="auth-footer">
            <a href="/login">&larr; Back to sign in</a>
        </div>

    </div>
</div>
{% endblock %}
