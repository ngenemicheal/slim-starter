{% extends 'layout.twig' %}

{% block content %}
<div class="page-narrow">
    <div class="card">

        <div class="card-title">Sign in</div>
        <div class="card-subtitle">Enter your email and password to continue.</div>

        {% if errors.general is defined %}
            <div class="alert alert-danger">{{ errors.general }}</div>
        {% endif %}

        <form method="POST" action="/login" novalidate>

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input id="email" name="email" type="email"
                       class="form-input {{ errors.email is defined ? 'error' : '' }}"
                       value="{{ old.email ?? '' }}"
                       autocomplete="email" required>
                {% if errors.email is defined %}
                    <div class="form-error">{{ errors.email }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input id="password" name="password" type="password"
                       class="form-input {{ errors.password is defined ? 'error' : '' }}"
                       autocomplete="current-password" required>
                {% if errors.password is defined %}
                    <div class="form-error">{{ errors.password }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary">Sign in</button>

        </form>

        <div class="auth-footer" style="text-align:center">
            <a href="/forgot-password">Forgot your password?</a>
        </div>

        <div class="auth-footer">
            Don't have an account? <a href="/register">Create one</a>
        </div>

    </div>
</div>
{% endblock %}
