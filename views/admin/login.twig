{% extends 'base.twig' %}

{% block head %}
    <link rel="stylesheet" href="/css/app.css">
    <link rel="stylesheet" href="/css/admin.css">
{% endblock %}

{% block body %}
<div class="admin-login-page">
    <div class="admin-login-card">

        <div class="admin-login-header">
            <strong>{{ app_name }}</strong>
            <span>Admin Panel — sign in to continue</span>
        </div>

        {% if flash_error is defined and flash_error %}
            <div class="alert alert-danger">{{ flash_error }}</div>
        {% endif %}

        {% if errors.general is defined %}
            <div class="alert alert-danger">{{ errors.general }}</div>
        {% endif %}

        <form method="POST" action="/admin/login" novalidate>

            <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input id="email" name="email" type="email"
                       class="form-input {{ errors.email is defined ? 'error' : '' }}"
                       value="{{ old.email ?? '' }}"
                       autocomplete="email" required autofocus>
                {% if errors.email is defined %}
                    <div class="form-error">{{ errors.email }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input id="password" name="password" type="password"
                       class="form-input {{ errors.password is defined ? 'error' : '' }}"
                       autocomplete="current-password" required>
                {% if errors.password is defined %}
                    <div class="form-error">{{ errors.password }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary" style="margin-top:.25rem">
                Sign in to Admin
            </button>

        </form>

        <div class="auth-footer" style="margin-top:1.25rem">
            <a href="/">&larr; Back to site</a>
        </div>

    </div>
</div>
{% endblock %}
