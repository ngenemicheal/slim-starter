{% extends 'emails/base.twig' %}

{% block subject %}Reset your password{% endblock %}

{% block body %}
<h1>Reset your password</h1>
<p>Hi {{ user.name }},</p>
<p>We received a request to reset the password for your account. Click the button below to choose a new password.</p>
<p>This link expires in <strong>60 minutes</strong>.</p>

<a href="{{ reset_url }}" class="btn">Reset Password</a>

<hr class="divider">

<p class="small">If the button doesn't work, copy and paste this URL into your browser:</p>
<p class="small">{{ reset_url }}</p>
<p class="small">If you didn't request a password reset, you can safely ignore this email — your password will not be changed.</p>
{% endblock %}
